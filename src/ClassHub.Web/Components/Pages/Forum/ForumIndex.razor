@page "/foro"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IUnitService UnitSvc

<PageTitle>Foro — ClassHub</PageTitle>

<div class="page-header">
    <a href="/" class="back-link">← Inicio</a>
    <h1>💬 Foro</h1>
    <p>Hilos de discusión organizados por unidad. La información queda siempre accesible.</p>
</div>

@if (_units is null)
{
    <p>Cargando...</p>
}
else
{
    <div class="cards-grid">
        @foreach (var u in _units)
        {
            <a href="/foro/@u.Id" class="card">
                <span class="unit-number">Unidad @u.Number</span>
                <h3>@u.Title</h3>
                <p>@u.Description</p>
            </a>
        }
    </div>
}

@code {
    private List<Unit>? _units;

    protected override async Task OnInitializedAsync()
        => _units = await UnitSvc.GetAllAsync();
}
